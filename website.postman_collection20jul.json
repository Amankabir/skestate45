{
  "info": {
    "name": "HG API (Website / Public)",
    "_postman_id": "b7e4d1a2-3c6f-5b8e-a1d0-9f2e7c4b6a3d",
    "description": "Public APIs for the customer-facing website. No authentication required.\n\n## Setup\n1. Import this file into Postman.\n2. Open collection **Variables** and set `base_url` (default `http://localhost:4000`).\n3. Run **List areas**, **List amenities**, **List property types**, or **List properties** — scripts save ids to collection variables.\n4. Use **Get by ID** requests with saved variables, or run **List properties (with filters)** for search.\n5. Use **Submit enquiry** to post a public contact form (include `pageUrl`).\n\n## Collection variables\n| Variable | Purpose |\n|----------|----------|\n| `base_url` | API base URL |\n| `area_id` | Auto-set from list areas |\n| `amenity_id` | Auto-set from list amenities |\n| `property_type_id` | Auto-set from list property types |\n| `property_id` | Auto-set from list properties |\n\nSee `docs/api/website.md` for full API documentation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000" },
    { "key": "area_id", "value": "" },
    { "key": "amenity_id", "value": "" },
    { "key": "property_type_id", "value": "" },
    { "key": "property_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/health",
            "description": "Quick check that the API server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Areas",
      "description": "Public area lookup for website filter dropdowns.",
      "item": [
        {
          "name": "List areas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.length > 0) {",
                  "    pm.collectionVariables.set('area_id', json.data[0].id);",
                  "    pm.test('area_id saved', () => pm.expect(json.data[0].id).to.be.a('string'));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/website/areas",
            "description": "Returns all areas sorted by name (A–Z). First result id is saved to `area_id`."
          },
          "response": []
        },
        {
          "name": "Get area by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/website/areas/{{area_id}}",
            "description": "Get a single area. Run **List areas** first to populate `area_id`."
          },
          "response": []
        }
      ]
    },
